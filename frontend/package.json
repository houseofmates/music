{
  "name": "music",
  "private": true,
  "version": "1.0.0",
  "description": "desktop music player app",
  "author": "house",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 3000",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run type-check && npm run format:check",
    "android": "npx cap open android",
    "android:sync": "npx cap sync android",
    "android:build": "npm run build && npx cap sync android && npx cap open android",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3006 && electron .\"",
    "electron:build": "VITE_API_URL=http://localhost:3006/api npm run build && electron-builder",
    "electron:build:linux": "VITE_API_URL=http://localhost:3006/api npm run build && electron-builder --linux",
    "electron:build:appimage": "npm run build && electron-builder --linux AppImage tar.gz"
  },
  "dependencies": {
    "@capacitor/android": "^5.7.0",
    "@capacitor/app": "^5.0.6",
    "@capacitor/core": "^5.7.0",
    "@capacitor/device": "^5.0.8",
    "@capacitor/splash-screen": "^5.0.6",
    "@capacitor/status-bar": "^5.0.6",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/annyang": "^2.6.0",
    "annyang": "^3.0.0",
    "axios": "^1.6.5",
    "cordova-plugin-background-mode": "^0.7.3",
    "cordova-plugin-device": "^3.0.0",
    "lucide-react": "^0.312.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.21.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@testing-library/jest-dom": "^6.4.1",
    "@testing-library/react": "^14.2.1",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/deep-eql": "^4.0.2",
    "@types/estree": "^1.0.8",
    "@types/node": "^25.5.2",
    "@types/plist": "^3.0.5",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/verror": "^1.10.11",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.4.33",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.house.music",
    "productName": "Music",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Audio",
      "icon": "electron/icons",
      "executableName": "music",
      "maintainer": "house",
      "vendor": "house",
      "synopsis": "Music player app",
      "description": "A desktop music player application"
    },
    "appImage": {
      "artifactName": "${productName}-${version}.${ext}",
      "category": "Audio"
    },
    "asar": false,
    "compression": "store"
  }
}
