# music-app environment template
# copy this file to .env and fill in your values

# required
MUSIC_DIR=/path/to/your/music/collection
DATABASE_URL=sqlite:///./music.db

# external apis
ACOUSTID_API_KEY=
MUSICBRAINZ_USER_AGENT=your-app/1.0 (you@example.com)

# ai
OLLAMA_URL=http://127.0.0.1:11434

# auth
JWT_SECRET_KEY=
PASSCODE_USER=
PASSCODE_HASH=

# server
HOST=0.0.0.0
PORT=8000
DEBUG=false
