# Application Settings
APP_NAME=pkm
APP_VERSION=1.0.0
DEBUG=False

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./data/music.db

# Music directory
MUSIC_DIR=/path/to/music

# External APIs
ACOUSTID_API_KEY=your_acoustid_key_here
MUSICBRAINZ_USER_AGENT=Music/1.0.0 (your-email@example.com)

# CORS (comma-separated list of allowed origins, no spaces)
CORS_ORIGINS=http://localhost:3006,http://localhost:5173

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Share links
SHARE_BASE_URL=

# External services (optional)
JELLYFIN_URL=
JELLYFIN_API_KEY=
YT_COOKIES_PATH=

# NVIDIA AI API Keys for Intelligent Features
# Get your keys from: https://integrate.api.nvidia.com/v1
# System uses round-robin rotation to distribute load and avoid rate limits
NVIDIA_API_KEY_1=your_nvidia_api_key_1_here
NVIDIA_API_KEY_2=your_nvidia_api_key_2_here
NVIDIA_API_KEY_3=your_nvidia_api_key_3_here
