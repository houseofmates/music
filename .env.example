# Environment variables for the music streaming server backend
# Copy this file to .env and fill in your actual values.

# --- Required ---
MUSIC_DIR=/path/to/your/music/collection

# --- Database ---
DATABASE_URL=sqlite:///./music.db

# --- External APIs ---
ACOUSTID_API_KEY=
MUSICBRAINZ_USER_AGENT=your-app/1.0 (your-email@example.com)

# --- AI / OLLAMA ---
OLLAMA_URL=http://127.0.0.1:11434

# --- Auth ---
JWT_SECRET_KEY=
PASSCODE_USER=
PASSCODE_HASH=

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=false
